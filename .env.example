APP_NAME=LaraJob
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Admin account created by `php artisan db:seed` (AdminSeeder), every
# environment. Leave both unset locally to use the documented demo login
# (admin@larajob.test / password). In production, always set ADMIN_PASSWORD
# yourself — an unset password there gets a random one generated and printed
# once instead of a guessable default.
# ADMIN_EMAIL=admin@larajob.test
# ADMIN_PASSWORD=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev default: sqlite (zero setup). Production (Railway) runs
# PostgreSQL with pgvector — see docs/deploy-railway.md. To develop against
# Postgres instead, switch DB_CONNECTION=pgsql and fill in the block below;
# migrations enable the pgvector extension automatically.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=larajob
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@larajob.test"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage for user uploads (resumes/CVs). Resumes are stored on a
# private, S3-compatible disk so they survive Railway's ephemeral disk on
# redeploy. Works with AWS S3 and Cloudflare R2.
#
# Leave these empty for local dev: resumes then fall back to the private
# local disk automatically (RESUME_DISK defaults to "local" when no bucket
# is set). Set them in production to route resumes to object storage.
#
# RESUME_DISK explicitly picks the disk ("s3" or "local"); it defaults to
# "s3" whenever AWS_BUCKET is set, otherwise "local".
# RESUME_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Cloudflare R2: set the S3 API endpoint, e.g.
# AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# AWS_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"

# AI layer — provider-agnostic, driven by App\Services\AI\AIService.
# Provider switch: none | openai | ollama. Default "none" keeps the whole
# AI layer disabled so the app runs with zero AI configuration.
AI_PROVIDER=none

# OpenAI — required only when AI_PROVIDER=openai. Leave empty otherwise.
OPENAI_API_KEY=

# Ollama — local models; used only when AI_PROVIDER=ollama.
OLLAMA_URL=http://localhost:11434

# --- AI cost & abuse controls (see config/ai.php) ---
# Soft global daily budget: max real model calls per day across all users.
# When reached, every AI feature degrades to its rule-based fallback for the
# rest of the day (fail safe, not fail expensive). 0 = unlimited (default).
AI_DAILY_CALL_BUDGET=0

# Per-user daily caps per feature. Over a cap, that feature degrades to its
# fallback for the rest of the day. Defaults shown; tune per environment.
# AI_CAP_MATCH_EXPLAIN=200
# AI_CAP_ASK=100
# AI_CAP_COVER_LETTER=30
# AI_CAP_JOB_DESCRIPTION=50
# AI_CAP_BIAS_CHECK=100
# AI_CAP_CV_PARSE=10
# Re-parsing the exact same resume file within this window is skipped.
# AI_CV_PARSE_DEBOUNCE_MINUTES=10
